{
  "type": "module",
  "name": "mmv-couture-platform",
  "private": true,
  "version": "1.0.0",
  "description": "Plateforme de gestion pour ateliers de couture",
  "author": "MMV Couture",
  "scripts": {
    "dev": "vite",
    "build": "tailwindcss -i ./styles/index.css -o ./dist/index.css && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "electron-dev": "vite & electron .",
    "electron-build": "npm run build && electron-builder",
    "android-sync": "npx cap sync android",
    "android-build": "npm run build && npx cap sync android && cd android && ./gradlew bundleRelease",
    "android-debug": "npm run build && npx cap sync android && cd android && ./gradlew installDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/cli": "^8.0.2",
    "@capacitor/core": "^8.0.2",
    "dotenv": "^17.2.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "electron-is-dev": "^3.0.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "nsis": "^0.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "homepage": "./",
  "main": "public/electron-main.js",
  "build": {
    "appId": "com.mmvcouture.app",
    "productName": "MMV Couture",
    "directories": {
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
